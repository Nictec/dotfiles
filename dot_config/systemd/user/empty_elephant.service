[Unit]
Description=Elephant - Backend for Walker launcher
PartOf=graphical-session.target
After=graphical-session.target

[Service]
Type=exec
# Replace 'elephant' with the full path if it's not in your PATH
ExecStart=/usr/bin/elephant
Restart=on-failure
RestartSec=3

[Install]
WantedBy=graphical-session.target
