#
# ~/.bashrc
#

# If not running interactively, don't do anything
[[ $- != *i* ]] && return

alias ls='ls --color=auto'
alias grep='grep --color=auto'
PS1='[\u@\h \W]\$ '

# custom aliases
alias vi=nvim

# ENV Variables
export EDITOR="/bin/nvim"

# prompt
eval "$(starship init bash)"

# rust
. "$HOME/.cargo/env"

# kitty
alias s="kitten ssh"
